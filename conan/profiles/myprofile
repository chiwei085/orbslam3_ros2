[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=11
compiler.libcxx=libstdc++11
compiler.cppstd=17
build_type=Release

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
tools.build:compiler_executables={"c":"gcc","cpp":"g++"}
tools.cmake.cmaketoolchain:extra_variables={"CMAKE_CXX_STANDARD":"17","CMAKE_POSITION_INDEPENDENT_CODE":"ON"}
g2o_orbslam3/*:tools.build:cxxflags=["-DEIGEN_DONT_VECTORIZE","-DEIGEN_DISABLE_UNALIGNED_ARRAY_ASSERT","-DEIGEN_MAX_ALIGN_BYTES=0","-fno-fast-math"]

[options]
opencv/*:with_ffmpeg=False
opencv/*:with_wayland=False
opencv/*:with_gtk=False
